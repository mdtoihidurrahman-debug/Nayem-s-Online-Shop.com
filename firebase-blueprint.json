{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Store customer profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The Firebase Auth UID" },
        "displayName": { "type": "string", "description": "The customer's name" },
        "email": { "type": "string", "format": "email", "description": "The customer's email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Store customer orders",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Customer profiles mapped by UID"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
